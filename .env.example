# ── Database Connection ───────────────────────────────────────────────────────
SALES_DB_USER=your_db_user
SALES_DB_PASSWORD=your_db_password
SALES_DB_HOST=127.0.0.1
SALES_DB_PORT=5432
SALES_DB_NAME=your_database_name
# SALES_DB_URL=postgresql://user:password@host:5432/dbname

# ── AI Model Keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Engine Behaviour ──────────────────────────────────────────────────────────
# false = full SQL queries (recommended); true = views only (limited)
STRICT_VIEW_ONLY=false
FAST_MODE=true
USE_PRECOMPUTED_ASSOC=true
ENABLE_REALTIME_PARTNER_SCORING=false
RANK_BY_MARGIN=true

# ── Look-back windows ─────────────────────────────────────────────────────────
GAP_LOOKBACK_DAYS=365
MBA_LOOKBACK_MONTHS=12
CHURN_HISTORY_MONTHS=15
CHURN_HORIZON_DAYS=90
FORECAST_HISTORY_MONTHS=6

# ── Risk thresholds ───────────────────────────────────────────────────────────
CHURN_PROB_HIGH=0.65
CHURN_PROB_MEDIUM=0.35
CREDIT_RISK_HIGH=0.67
CREDIT_RISK_MEDIUM=0.40

# ── Market Basket ─────────────────────────────────────────────────────────────
MBA_MIN_CONFIDENCE=0.15
MBA_MIN_LIFT=1.0
MBA_MIN_SUPPORT=5
MBA_INCLUDE_LOW_SUPPORT=false

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CORE_CACHE_TTL_SEC=900
CLUSTER_CACHE_TTL_SEC=900
ASSOC_CACHE_TTL_SEC=900
CHURN_CACHE_TTL_SEC=1800
CREDIT_CACHE_TTL_SEC=1800

# ── Clustering ────────────────────────────────────────────────────────────────
CLUSTER_MIN_STABILITY_ARI=0.0
CLUSTER_OUTLIER_MIN=0.0
CLUSTER_OUTLIER_MAX=0.60
CLUSTER_MIN_COUNT=2
CLUSTER_VIP_PERCENTILE=0.80
CLUSTER_VIP_MIN_SHARE=0.20
CLUSTER_VIP_MAX_SHARE=0.45
CLUSTER_GROWTH_OUTLIER_REASSIGN=true
CLUSTER_GROWTH_REASSIGN_DISTANCE_Q=0.90
CLUSTER_GROWTH_REASSIGN_DISTANCE_MULT=1.15
CLUSTER_GROWTH_HIGH_VALUE_Q=0.70
CLUSTER_GROWTH_REASSIGN_HIGH_VALUE_MULT=1.50
CLUSTER_GROWTH_FALLBACK_OUTLIER_RATIO=0.50

# ── Alerts ────────────────────────────────────────────────────────────────────
ALERT_REVENUE_DROP_SHARP_PCT=35.0
ALERT_CHURN_JUMP_DELTA=0.15
ALERT_CHURN_HIGH_LEVEL=0.45
ALERT_CREDIT_JUMP_DELTA=0.15
ALERT_CREDIT_HIGH_LEVEL=0.55

# ── Misc ──────────────────────────────────────────────────────────────────────
SALES_DB_CONNECT_TIMEOUT=5
NL_QUERY_PARTNER_SCAN_LIMIT=300
OMP_NUM_THREADS=1
